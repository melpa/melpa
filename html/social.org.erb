<%
  repo_title = "MELPA"
  repo_nick = "MELPA"
  base_url = "https://melpa.org"
  description = "The largest and most up-to-date repository of Emacs packages"

  if File.absolute_path(__FILE__).include? "html-snapshots"
    repo_title = "MELPA Snapshots"
    repo_nick = "MELPA_Snapshots"
    base_url = "https://snapshots.melpa.org"
    description = "Development snapshots of Emacs packages from MELPA"
  end
%>#+TITLE: <%= repo_title %>
#+NICK: <%= repo_nick %>
#+DESCRIPTION: <%= description %>
#+AVATAR: <%= base_url %>/logo.svg
#+LINK: <%= base_url %>
#+LANGUAGE: en
#+CONTACT: https://github.com/melpa/melpa

* Posts
<%
  require 'json'
  require 'time'
  require 'ostruct'

  packages = JSON.parse(File.read("archive.json")).map do |pkgname, info|
    versions = info["ver"]
    version = versions.join('.')

    # The build time is encoded at the end of the version: [YYYYMMDD, HHMM]
    # on melpa.org, or appended to the upstream version (e.g.
    # [1, 0, 2, 0, 20190703, 5]) on snapshots.melpa.org.
    date = versions.length >= 2 ? versions[-2] : versions[0]
    hhmm = versions.length >= 2 ? versions[-1] : 0
    next unless date.is_a?(Integer) && date >= 19700101

    begin
      build_time = Time.new(date / 10000, date / 100 % 100, date % 100,
                            hhmm / 100, hhmm % 100)
    rescue ArgumentError, TypeError
      next
    end

    package = OpenStruct.new
    package.name = pkgname
    package.version = version
    package.description = info["desc"].gsub(/ \[source:.*$/, '')
    package.build_time = build_time
    package.url = "#{base_url}/packages/#{pkgname}-#{version}." + (info["type"] == "single" ? "el" : "tar")
    package.info_url = "#{base_url}/#/#{pkgname}"
    package
  end.compact

  posts = packages.sort_by { |p| [p.build_time, p.name] }.reverse[0...200]

  # Post IDs (the timestamps) must be unique within the feed: nudge
  # packages built in the same minute one second apart.
  used_ids = {}
  posts.each do |package|
    package.build_time += 1 while used_ids[package.build_time]
    used_ids[package.build_time] = true
  end

  posts.each do |package|
%>** <%= package.build_time.strftime("%Y-%m-%dT%H:%M:%S%z") %>
:PROPERTIES:
:LANG: en
:TAGS: emacs package <%= package.name %>
:BOT: package-update <%= package.name %> <%= package.version %>
:END:

📦 *<%= package.name %>* updated to version ~<%= package.version %>~

<%= package.description %>

🔗 [[<%= package.info_url %>][View package details]]
⬇️  [[<%= package.url %>][Download]]

<% end %>
